{
  "dashboard": {
    "id": null,
    "title": "EduSubmit Application Dashboard",
    "tags": ["edusubmit", "spring-boot", "backend"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Service Status",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up{job=\"edusubmit-backend\"}",
            "legendFormat": "{{instance}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}
          }
        }
      },
      {
        "id": 2,
        "title": "JVM Memory Used",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{job=\"edusubmit-backend\", area=\"heap\"} / 1024 / 1024",
            "legendFormat": "Heap Used MB"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 512}, {"color": "red", "value": 1024}]}
          }
        }
      },
      {
        "id": 3,
        "title": "CPU Usage",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"edusubmit-backend\"}[5m]) * 100",
            "legendFormat": "CPU %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
          }
        }
      },
      {
        "id": 4,
        "title": "Database Connections",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "hikaricp_connections_active{job=\"edusubmit-backend\"}",
            "legendFormat": "Active"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 8}, {"color": "red", "value": 10}]}
          }
        }
      },
      {
        "id": 5,
        "title": "HTTP Request Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"edusubmit-backend\"}[5m])",
            "legendFormat": "Requests/sec"
          }
        ],
        "yAxes": [{"label": "Requests/sec"}]
      },
      {
        "id": 6,
        "title": "Response Time (95th Percentile)",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"edusubmit-backend\"}[5m]))",
            "legendFormat": "95th Percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"edusubmit-backend\"}[5m]))",
            "legendFormat": "50th Percentile"
          }
        ],
        "yAxes": [{"label": "Seconds"}]
      },
      {
        "id": 7,
        "title": "JVM Memory Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{job=\"edusubmit-backend\", area=\"heap\"} / 1024 / 1024",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "jvm_memory_committed_bytes{job=\"edusubmit-backend\", area=\"heap\"} / 1024 / 1024",
            "legendFormat": "Heap Committed"
          }
        ],
        "yAxes": [{"label": "MB"}]
      },
      {
        "id": 8,
        "title": "Garbage Collection",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_count{job=\"edusubmit-backend\"}[5m])",
            "legendFormat": "GC Count/sec"
          },
          {
            "expr": "rate(jvm_gc_pause_seconds_sum{job=\"edusubmit-backend\"}[5m])",
            "legendFormat": "GC Time/sec"
          }
        ],
        "yAxes": [{"label": "Count/Seconds"}]
      },
      {
        "id": 9,
        "title": "Thread Count",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "jvm_threads_live_threads{job=\"edusubmit-backend\"}",
            "legendFormat": "Live Threads"
          },
          {
            "expr": "jvm_threads_peak_threads{job=\"edusubmit-backend\"}",
            "legendFormat": "Peak Threads"
          }
        ],
        "yAxes": [{"label": "Threads"}]
      },
      {
        "id": 10,
        "title": "HTTP Error Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"edusubmit-backend\",status=~\"5..\"}[5m])",
            "legendFormat": "5xx Errors/sec"
          },
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"edusubmit-backend\",status=~\"4..\"}[5m])",
            "legendFormat": "4xx Errors/sec"
          }
        ],
        "yAxes": [{"label": "Errors/sec"}]
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "15s"
  }
}
