# EduSubmit Environment Variables Example
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=edusubmit
MYSQL_USER=edusubmit_user
MYSQL_PASSWORD=change_this_password
MYSQL_PORT=3306

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_PORT=6379

# ============================================
# MINIO OBJECT STORAGE CONFIGURATION
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# SPRING BOOT CONFIGURATION
# ============================================
SPRING_PROFILES_ACTIVE=prod
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Change this to a strong random string in production
# Generate with: openssl rand -base64 32
JWT_SECRET=change_this_jwt_secret_in_production

# ============================================
# AI ENGINE CONFIGURATION
# ============================================
AI_ENGINE_PORT=5000
FLASK_ENV=production
DEBUG=False

# ============================================
# FRONTEND CONFIGURATION
# ============================================
FRONTEND_PORT=3000
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443
REACT_APP_API_BASE_URL=https://edusubmit.com/api
REACT_APP_AUTH_BASE_URL=https://edusubmit.com/auth

# ============================================
# MONITORING CONFIGURATION
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password
GRAFANA_ALLOW_SIGN_UP=false

# ============================================
# DOCKER REGISTRY CONFIGURATION
# ============================================
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password

# ============================================
# SONARQUBE CONFIGURATION
# ============================================
SONAR_TOKEN=your_sonarqube_token
SONAR_ORGANIZATION=your_sonarqube_organization
SONAR_PROJECT_KEY=edusubmit-backend

# ============================================
# AWS CONFIGURATION (for deployment)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_EC2_INSTANCE_TYPE=t2.medium
AWS_S3_BUCKET=edusubmit-deployments

# ============================================
# SSL CERTIFICATE CONFIGURATION
# ============================================
SSL_EMAIL=admin@edusubmit.com
SSL_DOMAIN=edusubmit.com

# ============================================
# EMAIL CONFIGURATION (for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@edusubmit.com

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Maximum file upload size in MB
MAX_FILE_SIZE=10

# Session timeout in minutes
SESSION_TIMEOUT=30

# Rate limiting requests per minute
RATE_LIMIT_PER_MINUTE=100

# Enable/disable features
ENABLE_AI_GRADING=true
ENABLE_PLAGIARISM_DETECTION=true
ENABLE_EMAIL_NOTIFICATIONS=true
