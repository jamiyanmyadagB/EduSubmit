# Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=edusubmit_prod
MYSQL_USER=edusubmit_user
MYSQL_PASSWORD=your_secure_user_password_here

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_characters_long_minimum

# MinIO/S3 Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_admin_password
MINIO_DEFAULT_BUCKETS=edusubmit-prod
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# Grafana Configuration
GRAFANA_PASSWORD=your_secure_grafana_password

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@edusubmit.com

# AI Service Configuration
AI_SERVICE_URL=http://localhost:5000
AI_API_KEY=your_ai_service_api_key

# Monitoring Configuration
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Application URLs
FRONTEND_URL=https://edusubmit.com
API_GATEWAY_URL=https://api.edusubmit.com

# Security Configuration
CORS_ALLOWED_ORIGINS=https://edusubmit.com,https://www.edusubmit.com
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST_CAPACITY=200

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=edusubmit-backups

# SSL Configuration (for production)
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem

# Performance Tuning
JAVA_OPTS=-Xmx512m -Xms256m
CONNECTION_POOL_SIZE=20
QUERY_TIMEOUT=30000

# Feature Flags
ENABLE_AI_GRADING=true
ENABLE_PLAGIARISM_DETECTION=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_FILE_ENCRYPTION=true
