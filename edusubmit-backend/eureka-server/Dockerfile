# Use a lightweight JRE image
FROM eclipse-temurin:17-jre-alpine

# Set the working directory
WORKDIR /app

# Copy the executable JAR file generated by your build process
COPY eureka-server/target/eureka-server-1.0.0.jar app.jar

# Expose the Eureka default port
EXPOSE 8761

# Run the application
ENTRYPOINT ["java", "-jar", "app.jar"]