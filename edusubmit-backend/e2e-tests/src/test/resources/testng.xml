<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="EduSubmit E2E Test Suite" verbose="1" parallel="tests" thread-count="1" data-provider-thread-count="1">
    
    <parameter name="browser" value="${browser}"/>
    <parameter name="headless" value="${headless}"/>
    <parameter name="baseUrl" value="${baseUrl}"/>
    <parameter name="environment" value="${environment}"/>

    <listeners>
        <listener class-name="com.edusubmit.e2e.listeners.TestListener"/>
        <listener class-name="com.edusubmit.e2e.listeners.ExtentReportListener"/>
    </listeners>

    <!-- Authentication Tests -->
    <test name="Authentication Tests">
        <classes>
            <class name="com.edusubmit.e2e.tests.AuthenticationTest"/>
        </classes>
    </test>

    <!-- Student Dashboard Tests -->
    <test name="Student Dashboard Tests">
        <classes>
            <class name="com.edusubmit.e2e.tests.StudentDashboardTest"/>
        </classes>
    </test>

    <!-- Faculty Dashboard Tests -->
    <test name="Faculty Dashboard Tests">
        <classes>
            <class name="com.edusubmit.e2e.tests.FacultyDashboardTest"/>
        </classes>
    </test>

    <!-- Admin Dashboard Tests -->
    <test name="Admin Dashboard Tests">
        <classes>
            <class name="com.edusubmit.e2e.tests.AdminDashboardTest"/>
        </classes>
    </test>

</suite>
