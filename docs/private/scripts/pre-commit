#!/bin/bash

# Pre-commit hook for EduSubmit project
# Prevents accidental commits of secrets, API keys, and sensitive data

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PATTERNS_FILE="$SCRIPT_DIR/secret-patterns.txt"

echo -e "${BLUE}🔍 Running pre-commit security scan...${NC}"

# Function to check if a file should be scanned
should_scan_file() {
    local file="$1"
    
    # Skip binary files
    if [[ "$file" =~ \.(jpg|jpeg|png|gif|bmp|ico|pdf|zip|tar|gz|exe|dll|so|dylib)$ ]]; then
        return 1
    fi
    
    # Skip lock files and dependency files
    if [[ "$file" =~ (package-lock\.json|yarn\.lock|\.gradle|\.maven|pom\.xml)$ ]]; then
        return 1
    fi
    
    # Skip minified files
    if [[ "$file" =~ \.min\.(js|css)$ ]]; then
        return 1
    fi
    
    return 0
}

# Function to scan a file for secrets
scan_file_for_secrets() {
    local file="$1"
    local found_secrets=()
    
    # Read patterns file or use default patterns
    if [ -f "$PATTERNS_FILE" ]; then
        while IFS= read -r pattern; do
            # Skip empty lines and comments
            [[ -z "$pattern" || "$pattern" =~ ^[[:space:]]*# ]] && continue
            
            # Search for pattern in file
            if grep -q -E "$pattern" "$file" 2>/dev/null; then
                found_secrets+=("$pattern")
            fi
        done < "$PATTERNS_FILE"
    else
        # Default patterns if patterns file doesn't exist
        local default_patterns=(
            "AKIA[0-9A-Z]{16}"                                    # AWS Access Key
            "(?i)aws[_-]?secret[_-]?access[_-]?key['\"]?\s*[:=]\s*['\"]?[A-Za-z0-9/+=]{40}"
            "(?i)api[_-]?key['\"]?\s*[:=]\s*['\"]?[A-Za-z0-9_-]{20,}"
            "(?i)secret[_-]?key['\"]?\s*[:=]\s*['\"]?[A-Za-z0-9_-]{20,}"
            "(?i)password['\"]?\s*[:=]\s*['\"]?[^\s'\"]{8,}"
            "(?i)token['\"]?\s*[:=]\s*['\"]?[A-Za-z0-9_-]{20,}"
            "-----BEGIN [A-Z]+ KEY-----"                          # Private keys
            "-----BEGIN CERTIFICATE-----"                         # Certificates
            "(?i)mysql[_-]?password['\"]?\s*[:=]\s*['\"]?[^\s'\"]+"
            "(?i)postgres[_-]?password['\"]?\s*[:=]\s*['\"]?[^\s'\"]+"
            "(?i)mongodb[_-]?uri['\"]?\s*[:=]\s*['\"]?mongodb://[^\s'\"]+"
            "(?i)redis[_-]?password['\"]?\s*[:=]\s*['\"]?[^\s'\"]+"
            "(?i)jwt[_-]?secret['\"]?\s*[:=]\s*['\"]?[A-Za-z0-9_-]{20,}"
            "sk-[a-zA-Z0-9]{20,}"                                # Stripe API keys
            "ghp_[a-zA-Z0-9]{36}"                                # GitHub personal access tokens
            "xoxb-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24}"     # Slack bot tokens
            "AIza[0-9A-Za-z_-]{35}"                              # Google API keys
        )
        
        for pattern in "${default_patterns[@]}"; do
            if grep -q -E "$pattern" "$file" 2>/dev/null; then
                found_secrets+=("$pattern")
            fi
        done
    fi
    
    # If secrets found, show details
    if [ ${#found_secrets[@]} -gt 0 ]; then
        echo -e "${RED}❌ POTENTIAL SECRETS DETECTED in $file:${NC}"
        for pattern in "${found_secrets[@]}"; do
            echo -e "${YELLOW}   Pattern: $pattern${NC}"
            # Show matching lines (but mask the actual secret)
            grep -n -E "$pattern" "$file" 2>/dev/null | head -5 | while read -r line; do
                # Mask potential secrets in the output
                masked_line=$(echo "$line" | sed -E 's/([A-Za-z0-9_-]{8,})/*****/g')
                echo -e "${RED}     Line $masked_line${NC}"
            done
        done
        return 1
    fi
    
    return 0
}

# Get list of files to be committed
files_to_commit=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$files_to_commit" ]; then
    echo -e "${GREEN}✅ No files to scan.${NC}"
    exit 0
fi

echo -e "${BLUE}📁 Scanning $(echo "$files_to_commit" | wc -l) file(s)...${NC}"

# Track if any secrets were found
secrets_found=false
scanned_files=0

# Scan each file
for file in $files_to_commit; do
    if [ -f "$file" ] && should_scan_file "$file"; then
        ((scanned_files++))
        if ! scan_file_for_secrets "$file"; then
            secrets_found=true
        fi
    fi
done

echo -e "${BLUE}📊 Scanned $scanned_files file(s)${NC}"

# Final result
if [ "$secrets_found" = true ]; then
    echo ""
    echo -e "${RED}🚨 COMMIT BLOCKED!${NC}"
    echo -e "${RED}   Potential secrets or sensitive data detected in your commit.${NC}"
    echo ""
    echo -e "${YELLOW}📋 What to do:${NC}"
    echo -e "   1. Remove the sensitive data from the files"
    echo -e "   2. Use environment variables or configuration files"
    echo -e "   3. Add the files to .gitignore if they contain secrets"
    echo -e "   4. Use git reset HEAD <file> to unstage sensitive files"
    echo ""
    echo -e "${BLUE}💡 Tip: Use placeholder values like 'YOUR_API_KEY_HERE' in code${NC}"
    echo ""
    exit 1
else
    echo -e "${GREEN}✅ No secrets detected. Commit allowed.${NC}"
    exit 0
fi
