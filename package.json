{
  "name": "edusubmit-fullstack",
  "version": "1.0.0",
  "description": "EduSubmit - Full Stack Development Setup",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd edusubmit-frontend && npm start",
    "dev:backend": "cd edusubmit-backend && mvn spring-boot:run -pl api-gateway,auth-service,assignment-service",
    "install:all": "npm run install:frontend && npm run install:backend",
    "install:frontend": "cd edusubmit-frontend && npm install --legacy-peer-deps",
    "install:backend": "cd edusubmit-backend && mvn clean install -DskipTests",
    "build:frontend": "cd edusubmit-frontend && npm run build",
    "build:backend": "cd edusubmit-backend && mvn clean package -DskipTests",
    "docker:up": "docker-compose -f docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker-compose.yml down",
    "docker:logs": "docker-compose -f docker-compose.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": ["education", "assignment", "spring-boot", "react", "fullstack"],
  "author": "EduSubmit Team"
}
